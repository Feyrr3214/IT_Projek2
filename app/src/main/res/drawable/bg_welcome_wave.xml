<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="360dp"
    android:height="440dp"
    android:viewportWidth="360"
    android:viewportHeight="440">

    <!-- Shadow layer -->
    <path
        android:fillColor="#1A000000"
        android:pathData="M0,0 L360,0 L360,224 C280,244 140,414 0,344 Z" />

    <!-- Main Purple Wave -->
    <path
        android:pathData="M0,0 L360,0 L360,220 C280,240 140,410 0,340 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="360"
                android:endY="440"
                android:type="linear">
                <item android:offset="0" android:color="#9D8CEF" />
                <item android:offset="1" android:color="#7866CD" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Lighter wave accent -->
    <path
        android:fillColor="#20FFFFFF"
        android:pathData="M0,0 L360,0 L360,180 C260,280 180,360 0,290 Z" />

</vector>
