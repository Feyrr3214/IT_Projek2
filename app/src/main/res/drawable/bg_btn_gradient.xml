<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#44FFFFFF">
    <item>
        <shape android:shape="rectangle">
            <!-- Radius melengkung maksimal untuk kesan kapsul UI kekinian -->
            <corners android:radius="28dp" />
            
            <!-- Gradasi memukau dari ungu terang ke agak gelap miring 45 derajat -->
            <gradient
                android:startColor="@color/primary_purple"
                android:endColor="@color/primary_purple_dark"
                android:angle="45"
                android:type="linear" />
        </shape>
    </item>
</ripple>
