<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config — Keamanan jaringan aplikasi.
    - Larang cleartext (HTTP) untuk semua domain
    - Trust system CA untuk koneksi HTTPS
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
