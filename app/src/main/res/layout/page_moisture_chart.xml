<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="20dp"
    android:paddingBottom="12dp">

    <!-- Header baris atas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_water_drop"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Riwayat Kelembaban"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <!-- Petunjuk swipe balik -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ Gauge"
            android:textSize="11sp"
            android:textColor="#90FFFFFF"
            android:layout_marginEnd="4dp" />

    </LinearLayout>

    <!-- Chip filter periode (horizontal scroll) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="14dp">

        <LinearLayout
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipHariIni"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Hari ini"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_selected"
                android:textAppearance="@style/TextAppearance.AppCompat.Small" />

            <TextView
                android:id="@+id/chipKemarin"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Kemarin"
                android:textSize="12sp"
                android:textColor="#CCE8E6FF"
                android:textStyle="normal"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_unselected" />

            <TextView
                android:id="@+id/chipMingguIni"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Minggu ini"
                android:textSize="12sp"
                android:textColor="#CCE8E6FF"
                android:textStyle="normal"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_unselected" />

            <TextView
                android:id="@+id/chipBulanIni"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Bulan ini"
                android:textSize="12sp"
                android:textColor="#CCE8E6FF"
                android:textStyle="normal"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_unselected" />

            <TextView
                android:id="@+id/chipBulanKemarin"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Bulan kemarin"
                android:textSize="12sp"
                android:textColor="#CCE8E6FF"
                android:textStyle="normal"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_chip_unselected" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Chart View -->
    <com.example.itprojek2.ui.home.MoistureChartView
        android:id="@+id/moistureChartView"
        android:layout_width="match_parent"
        android:layout_height="200dp" />

</LinearLayout>
