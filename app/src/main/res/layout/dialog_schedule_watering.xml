<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="16dp"
    app:cardBackgroundColor="@color/surface_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Icon + Title + Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/shape_icon_circle_purple"
                android:src="@drawable/ic_schedule"
                android:tint="@color/primary_purple"
                android:padding="8dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFormTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Form Jadwal"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Atur waktu penyiraman otomatis"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/background_light"
            android:layout_marginBottom="16dp" />

        <!-- Label Waktu -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰  Waktu Penyiraman"
            android:textColor="@color/text_dark"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Format 24 jam · contoh 06:00 = pagi, 18:30 = sore"
            android:textColor="@color/text_gray"
            android:textSize="11sp"
            android:layout_marginBottom="12dp" />

        <!-- Jam &amp; Menit Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- Kolom Jam -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jam (0–23)"
                    android:textColor="@color/text_gray"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/primary_purple"
                    app:hintTextColor="@color/primary_purple">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etScheduleHour"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:hint="Jam"
                        android:inputType="number"
                        android:maxLength="2"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_purple_dark"
                        android:text="06" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Separator : -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" : "
                android:textColor="@color/primary_purple_dark"
                android:textSize="30sp"
                android:textStyle="bold"
                android:paddingTop="16dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <!-- Kolom Menit -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Menit (0–59)"
                    android:textColor="@color/text_gray"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/primary_purple"
                    app:hintTextColor="@color/primary_purple">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etScheduleMinute"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:hint="Menit"
                        android:inputType="number"
                        android:maxLength="2"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_purple_dark"
                        android:text="00" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/background_light"
            android:layout_marginBottom="16dp" />

        <!-- Label Durasi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱  Durasi Pompa Menyala"
            android:textColor="@color/text_dark"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Berapa detik pompa menyala saat jadwal aktif"
            android:textColor="@color/text_gray"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />

        <!-- Durasi Slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderDuration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="5"
                android:valueTo="120"
                android:stepSize="5"
                android:value="10"
                app:thumbColor="@color/primary_purple"
                app:trackColorActive="@color/primary_purple"
                app:trackColorInactive="@color/background_light" />

            <TextView
                android:id="@+id/tvDurationValue"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="10 dtk"
                android:textColor="@color/primary_purple_dark"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tombol Aksi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelSchedule"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Batal"
                android:textColor="@color/primary_purple"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/primary_purple"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveSchedule"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Simpan Jadwal"
                android:textColor="@color/surface_white"
                app:backgroundTint="@color/primary_purple"
                app:cornerRadius="12dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
