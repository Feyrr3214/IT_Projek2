<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header Dialog -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_schedule"
            app:tint="@color/primary_purple" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="Daftar Jadwal"
            android:textColor="@android:color/black"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/btnCloseDialog"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="X"
            android:textColor="#757575"
            android:textStyle="bold"
            android:textSize="20sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Atur waktu penyiraman otomatis. Kamu bisa punya beberapa jadwal."
        android:textColor="#5a5a5a"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="#E0E0E0" />

    <!-- Tulisan Kosong Jika Tidak Ada Jadwal -->
    <TextView
        android:id="@+id/tvEmptyJadwal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:gravity="center"
        android:text="Belum ada jadwal penyiraman.\nTekan tombol di bawah untuk menambah."
        android:textColor="#9E9E9E"
        android:visibility="gone" />

    <!-- RecyclerView Daftar Jadwal -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvJadwal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
        android:maxHeight="350dp" />

    <!-- Tombol Tambah Jadwal Baru -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTambahJadwal"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:text="+ Tambah Jadwal Baru"
        android:textAllCaps="false"
        app:backgroundTint="@color/primary_purple"
        app:cornerRadius="8dp" />

</LinearLayout>
