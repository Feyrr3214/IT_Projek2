<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_top_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            android:tint="@color/surface_white"
            android:layout_marginEnd="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengaturan Perangkat"
            android:textColor="@color/surface_white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ========================================== -->
            <!-- STEP 1: HUBUNGKAN BLUETOOTH                -->
            <!-- ========================================== -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvStep1Badge"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/shape_icon_circle_blue"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/info_blue"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Hubungkan Bluetooth"
                    android:textColor="@color/primary_purple_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Sambungkan HP ke ESP32 lewat Bluetooth terlebih dahulu."
                android:textColor="@color/text_gray"
                android:textSize="13sp" />

            <!-- Status Koneksi Bluetooth -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBluetoothStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/CardStyle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/shape_icon_circle_blue"
                        android:src="@drawable/ic_bluetooth"
                        android:tint="@color/info_blue"
                        android:padding="10dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status Bluetooth"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvBluetoothStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Belum Terhubung"
                            android:textColor="@color/danger_red"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/viewStatusDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/shape_icon_circle_red" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tombol Hubungkan / Putuskan -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:text="Pindai Perangkat Bluetooth"
                android:textAllCaps="false"
                android:textSize="14sp"
                style="@style/ButtonBlue" />

            <!-- ========================================== -->
            <!-- STEP 2: KIRIM WIFI (Tersembunyi dulu)      -->
            <!-- ========================================== -->

            <LinearLayout
                android:id="@+id/layoutStep2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="24dp"
                    android:background="@color/divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvStep2Badge"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/shape_icon_circle_green"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@color/success_green"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Kirim Konfigurasi WiFi"
                        android:textColor="@color/primary_purple_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Masukkan nama dan password WiFi, lalu kirim ke ESP32. Setelah berhasil, Bluetooth akan otomatis terputus."
                    android:textColor="@color/text_gray"
                    android:textSize="13sp" />

                <!-- Input SSID -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/CardStyle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_wifi"
                            android:tint="@color/info_blue" />

                        <EditText
                            android:id="@+id/etSsid"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginStart="12dp"
                            android:background="@null"
                            android:hint="Nama WiFi (SSID)"
                            android:inputType="text"
                            android:textColor="@color/text_dark"
                            android:textColorHint="@color/text_gray"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Input Password -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    style="@style/CardStyle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_key"
                            android:tint="@color/info_blue" />

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginStart="12dp"
                            android:background="@null"
                            android:hint="Password WiFi"
                            android:inputType="textPassword"
                            android:textColor="@color/text_dark"
                            android:textColorHint="@color/text_gray"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tombol Kirim -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendWifi"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="24dp"
                    android:text="Kirim ke ESP32"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    app:icon="@drawable/ic_send"
                    app:iconGravity="textStart"
                    style="@style/ButtonPrimary" />

            </LinearLayout>

            <!-- ========================================== -->


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
